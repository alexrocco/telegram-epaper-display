# Telegram bot token from @BotFather (required).
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Source channel: numeric chat id (e.g. -1001234567890) or @username (required).
CHANNEL_ID=@my_channel

# How often to long-poll Telegram (Go duration). Default: 5s.
POLL_INTERVAL=5s

# HTTP listen address. Default: :8080
HTTP_ADDR=:8080

# How many recent messages to render on the display. Default: 5
MESSAGES_TO_SHOW=5

# Path for persisted messages + poll offset. Default: data/store.json
STORE_PATH=data/store.json
